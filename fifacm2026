        { id: 'r32_15', team1: 'Switzerland', team2: 'Algeria', score1: '', score2: '', nextMatchId: 'r16_8', nextSlot: 'team1' },
        { id: 'r32_16', team1: 'Colombia', team2: 'Ghana', score1: '', score2: '', nextMatchId: 'r16_8', nextSlot: 'team2' },
      ],
      roundOf16: [
        { id: 'r16_1', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'qf_1', nextSlot: 'team1' },
        { id: 'r16_2', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'qf_1', nextSlot: 'team2' },
        { id: 'r16_3', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'qf_2', nextSlot: 'team1' },
        { id: 'r16_4', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'qf_2', nextSlot: 'team2' },
        { id: 'r16_5', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'qf_3', nextSlot: 'team1' },
        { id: 'r16_6', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'qf_3', nextSlot: 'team2' },
        { id: 'r16_7', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'qf_4', nextSlot: 'team1' },
        { id: 'r16_8', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'qf_4', nextSlot: 'team2' },
      ],
      quarterFinals: [
        { id: 'qf_1', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'sf_1', nextSlot: 'team1' },
        { id: 'qf_2', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'sf_1', nextSlot: 'team2' },
        { id: 'qf_3', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'sf_2', nextSlot: 'team1' },
        { id: 'qf_4', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'sf_2', nextSlot: 'team2' },
      ],
      semiFinals: [
        { id: 'sf_1', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'final_1', nextSlot: 'team1', loserMatchId: 'tp_1', loserSlot: 'team1' },
        { id: 'sf_2', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'final_1', nextSlot: 'team2', loserMatchId: 'tp_1', loserSlot: 'team2' },
      ],
      final: [
        { id: 'final_1', team1: '', team2: '', score1: '', score2: '', nextMatchId: 'champ', nextSlot: null }
      ],
      thirdPlace: [
        { id: 'tp_1', team1: '', team2: '', score1: '', score2: '', nextMatchId: null, nextSlot: null }
      ],
      champion: ''
    };

    const handleClearAllData = () => {
      if (confirm("Are you sure?")) {
        // Clear the saved data
        localStorage.removeItem('wc2026_users');
        localStorage.removeItem('wc2026_official');
        // Check if google exists (i.e., running in Google Apps Script environment)
        if (typeof google !== 'undefined') {

          // Ask the backend for the real URL, then reload!
          google.script.run.withSuccessHandler((myWebAppUrl) => {
            console.log("Got the real URL from the backend:", myWebAppUrl);

            // Force the main browser window to refresh to that URL
            window.open(myWebAppUrl, "_top");
          }).getWebAppUrl();
        } else {
          localStorage.clear(); // Clear local storage for local testing
          location.reload(); // Fallback for local testing
        }
      }
    };

    // --- SCORING LOGIC ---
    function getMatchPoints(userM, actualM) {
      if (!actualM || actualM.score1 === '' || actualM.score2 === '') return null; // Real match not played yet
      if (userM.score1 === '' || userM.score2 === '') return 0; // User missed prediction

      const u1 = parseInt(userM.score1);
      const u2 = parseInt(userM.score2);
      const a1 = parseInt(actualM.score1);
      const a2 = parseInt(actualM.score2);

      const userWinner = u1 > u2 ? userM.team1 : userM.team2;
      const actualWinner = a1 > a2 ? actualM.team1 : actualM.team2;

      // The "or"(||) is the intentional here to allow the user to get points even if they predicted the wrong team but got the score right for one of the teams.
      // If "and" (&&) was used, the user would only get points if they predicted the correct team and the correct score, which is not the intended behavior.
      const sameTeams = userM.team1 === actualM.team1 || userM.team2 === actualM.team2;
      const exactScore = sameTeams && (u1 === a1 && u2 === a2);

      if (exactScore && actualWinner !== '') return 7;
      if (userWinner === actualWinner && userWinner !== '') return 5;

      return 0;
    }

    // --- HELPER TO CALCULATE FULL USER SCORE ---
    function calculateTotalScore(userBracket, actualBracket) {
      let total = 0;
      const rounds = ['roundOf32', 'roundOf16', 'quarterFinals', 'semiFinals', 'final', 'thirdPlace'];
      rounds.forEach(round => {
        userBracket[round].forEach((userM, idx) => {
          const pts = getMatchPoints(userM, actualBracket[round][idx]);
          if (pts) total += pts;
        });
      });
      return total;
    }

    // --- COMPONENTS ---
    function MatchCard({ match, actualMatch, mode, onScore }) {
      const points = (mode === 'user') ? getMatchPoints(match, actualMatch) : null;

      const pointsBadge = (points !== null) ? html`
        <div class="points-badge ${points === 7 ? 'pts-7' : points === 5 ? 'pts-5' : 'pts-0'}">
          ${points > 0 ? '+' : ''}${points}
        </div>
      ` : null;

      return html`
        <div class="match-card">
          ${pointsBadge}
          <div class="team-row">
            <span class="team-name">${match.team1}</span>
            <input type="text" class="score-input" value=${match.score1} onInput=${(e) => onScore(true, e.target.value.replace(/[^0-9]/g, ''))} disabled=${match.team1 === '' || match.team2 === ''} maxLength="2" />
          </div>
          <div class="team-row">
            <span class="team-name">${match.team2}</span>
            <input type="text" class="score-input" value=${match.score2} onInput=${(e) => onScore(false, e.target.value.replace(/[^0-9]/g, ''))} disabled=${match.team1 === '' || match.team2 === ''} maxLength="2" />
          </div>
        </div>
      `;
    }

    function WorldCupBracket() {
      const [users, setUsers] = useState(() => {
        const saved = localStorage.getItem('wc2026_users');
        if (saved) return JSON.parse(saved);
        // Use pasted public data if available, otherwise default to Player 1
        return publicData && publicData.users ? publicData.users : [{ id: '1', name: 'Player 1', bracket: JSON.parse(JSON.stringify(initialData)) }];
      });

      const [actualBracket, setActualBracket] = useState(() => {
        const saved = localStorage.getItem('wc2026_official');
        if (saved) return JSON.parse(saved);
        // Use pasted official results if available, otherwise use blank template
        return publicData && publicData.officialResults ? publicData.officialResults : JSON.parse(JSON.stringify(initialData));
      });

      const [activeUserId, setActiveUserId] = useState(users[0].id);
      const [mode, setMode] = useState('leaderboard'); // 'user', 'actual', or 'leaderboard'
      const [newUserName, setNewUserName] = useState('');

      // NEW STATE FOR MODAL
      const [showWinnerModal, setShowWinnerModal] = useState(false);
      const [simulatorUserId, setSimulatorUserId] = useState(users[0]?.id);

      useEffect(() => { localStorage.setItem('wc2026_users', JSON.stringify(users)); }, [users]);
      useEffect(() => { localStorage.setItem('wc2026_official', JSON.stringify(actualBracket)); }, [actualBracket]);

      const currentUser = users.find(u => u.id === activeUserId);
      const currentBracket = mode === 'user' ? currentUser.bracket : actualBracket;

      const handleSimulateWin = () => {
        const selectedUser = users.find(u => u.id === simulatorUserId);
        if (!selectedUser) return;

        const newActualBracket = JSON.parse(JSON.stringify(actualBracket));
        const userBracket = selectedUser.bracket;

        // Ordered chronologically so winners naturally cascade to the next rounds
        const rounds = ['roundOf32', 'roundOf16', 'quarterFinals', 'semiFinals', 'final', 'thirdPlace'];
        const targetRoundsMap = { r16: 'roundOf16', qf: 'quarterFinals', sf: 'semiFinals', final: 'final', tp: 'thirdPlace' };

        rounds.forEach(round => {
          newActualBracket[round].forEach((actualMatch, idx) => {
            // If the official match hasn't been played yet (no scores)
            if (actualMatch.score1 === '' && actualMatch.score2 === '') {
              const userMatch = userBracket[round][idx];

              // Only simulate if the user actually made a prediction for this slot
              if (userMatch.score1 !== '' && userMatch.score2 !== '') {
                // 1. Copy ONLY the user's scores
                actualMatch.score1 = userMatch.score1;
                actualMatch.score2 = userMatch.score2;

                // Remove the actual match value if is not corresponding to the user match (to avoid overwriting actual teams with empty values)
                if (actualMatch.team1 !== userMatch.team1) actualMatch.team1 = '';
                if (actualMatch.team2 !== userMatch.team2) actualMatch.team2 = '';

                const s1 = parseInt(actualMatch.score1);
                const s2 = parseInt(actualMatch.score2);

                // 2. Determine the winner using the ACTUAL teams currently in this slot
                if (!isNaN(s1) && !isNaN(s2) && s1 !== s2 && (actualMatch.team1 || actualMatch.team2)) {
                  const winner = s1 > s2 ? actualMatch.team1 : actualMatch.team2;
                  const loser = s1 > s2 ? actualMatch.team2 : actualMatch.team1;

                  // 3. Push the winner to the next match
                  if (actualMatch.nextMatchId) {
                    if (actualMatch.nextMatchId === 'champ') {
                      newActualBracket.champion = winner;
                    } else {
                      const [targetPrefix, targetNum] = actualMatch.nextMatchId.split('_');
                      const targetRoundKey = targetRoundsMap[targetPrefix];
                      newActualBracket[targetRoundKey][parseInt(targetNum) - 1][actualMatch.nextSlot] = winner;
                    }
                  }

                  // 4. Push the loser to the third-place match if applicable
                  if (actualMatch.loserMatchId) {
                    const [loserPrefix, loserNum] = actualMatch.loserMatchId.split('_');
                    newActualBracket.thirdPlace[parseInt(loserNum) - 1][actualMatch.loserSlot] = loser;
                  }
                }
              }
            }
          });
        });

        setActualBracket(newActualBracket);
        setShowWinnerModal(false);
        setMode('leaderboard');
      };
      const handleClearOfficial = () => {
        if (confirm("Are you sure you want to clear ALL Official Results? This cannot be undone.")) {
          setActualBracket(JSON.parse(JSON.stringify(initialData)));
        }
      };

      const handleAddUser = (e) => {
        e.preventDefault();
        if (!newUserName.trim()) return;

        const newUser = {
          id: Date.now().toString(),
          name: newUserName.trim(),
          bracket: JSON.parse(JSON.stringify(initialData))
        };

        // Logic: If the only user is the default "Player 1", replace them.
        // Otherwise, add the new user to the existing list.
        let updatedUsers;
        if (users.length === 1 && users[0].name === 'Player 1') {
          updatedUsers = [newUser];
        } else {
          updatedUsers = [...users, newUser];
        }

        setUsers(updatedUsers);
        setActiveUserId(newUser.id);
        setNewUserName('');
      };

      const handleRenameUser = () => {
        const newName = prompt(`Enter a new name for ${currentUser.name}:`, currentUser.name);
        if (newName && newName.trim() !== '') setUsers(users.map(u => u.id === activeUserId ? { ...u, name: newName.trim() } : u));
      };

      const handleDeleteUser = () => {
        if (confirm(`Are you sure you want to delete ${currentUser.name}?`)) {
          const updatedUsers = users.filter(u => u.id !== activeUserId);

          if (updatedUsers.length > 0) {
            setUsers(updatedUsers);
            setActiveUserId(updatedUsers[0].id); // Switch to the first remaining user
          } else {
            // If we deleted the last user, clear storage and reset to a blank state
            localStorage.removeItem('wc2026_users');
            setUsers([{ id: '1', name: 'Player 1', bracket: JSON.parse(JSON.stringify(initialData)) }]);
            setActiveUserId('1');
            alert("All users deleted. Resetting to default.");
          }
        }
      };

      const handleExportData = () => {
        const exportObj = { officialResults: actualBracket, users: users };
        // Removed the ', null, 2' so it outputs on a single line
        const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(exportObj));
        const anchor = document.createElement('a'); anchor.setAttribute("href", dataStr); anchor.setAttribute("download", "wc2026_multiplayer_data.json");
        document.body.appendChild(anchor); anchor.click(); anchor.remove();
      };

      const handleImportData = (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = (event) => {
          try {
            const importedData = JSON.parse(event.target.result);
            if (importedData.users && importedData.officialResults) {
              setUsers(importedData.users); setActualBracket(importedData.officialResults); setActiveUserId(importedData.users[0].id); alert("Data successfully imported!");
            } else alert("Invalid file format.");
          } catch (error) { alert("Error parsing file."); }
        };
        reader.readAsText(file);
        e.target.value = '';
      };

      const handleScoreUpdate = (roundKey, matchIndex, isTeam1, value) => {
        const newBracket = JSON.parse(JSON.stringify(currentBracket));
        const currentMatch = newBracket[roundKey][matchIndex];

        if (isTeam1) currentMatch.score1 = value; else currentMatch.score2 = value;

        const s1 = parseInt(currentMatch.score1);
        const s2 = parseInt(currentMatch.score2);
        if (isNaN(s1) || isNaN(s2)) {
          if (currentMatch.nextMatchId) {
            // FIX: Check if the next match is the champion slot
            if (currentMatch.nextMatchId === 'champ') {
              newBracket.champion = '';
            } else {
              const [targetPrefix, targetNum] = currentMatch.nextMatchId.split('_');
              const targetRoundsMap = { r16: 'roundOf16', qf: 'quarterFinals', sf: 'semiFinals', final: 'final', tp: 'thirdPlace' };
              const targetRoundKey = targetRoundsMap[targetPrefix];
              newBracket[targetRoundKey][parseInt(targetNum) - 1][currentMatch.nextSlot] = '';
            }
          }
        } else {
          if (!isNaN(s1) && !isNaN(s2) && s1 !== s2) {
            const winner = s1 > s2 ? currentMatch.team1 : currentMatch.team2;
            const loser = s1 > s2 ? currentMatch.team2 : currentMatch.team1;

            if (currentMatch.nextMatchId) {
              if (currentMatch.nextMatchId === 'champ') newBracket.champion = winner;
              else {
                const [targetPrefix, targetNum] = currentMatch.nextMatchId.split('_');
                const targetRoundsMap = { r16: 'roundOf16', qf: 'quarterFinals', sf: 'semiFinals', final: 'final', tp: 'thirdPlace' };
                const targetRoundKey = targetRoundsMap[targetPrefix];
                newBracket[targetRoundKey][parseInt(targetNum) - 1][currentMatch.nextSlot] = winner;
              }
            }

            if (currentMatch.loserMatchId) {
              const [loserPrefix, loserNum] = currentMatch.loserMatchId.split('_');
              newBracket.thirdPlace[parseInt(loserNum) - 1][currentMatch.loserSlot] = loser;
            }
          }
        }

        if (mode === 'actual') setActualBracket(newBracket);
        else setUsers(users.map(u => u.id === activeUserId ? { ...u, bracket: newBracket } : u));
      };

      const renderColumn = (matches, roundKey, startIndex = 0) => html`
        <div class="round-column">
          ${matches.map((match, idx) => html`
            <div class="match-wrapper">
              <${MatchCard}
                key=${match.id} match=${match} actualMatch=${actualBracket[roundKey][startIndex + idx]} mode=${mode}
                onScore=${(isTeam1, val) => handleScoreUpdate(roundKey, startIndex + idx, isTeam1, val)}
              />
            </div>
          `)}
        </div>
      `;

      // Sort users by score for the leaderboard
      const rankedUsers = [...users]
        .map(u => ({ ...u, score: calculateTotalScore(u.bracket, actualBracket) }))
        .sort((a, b) => b.score - a.score);

      return html`
        <div>
          <h1>Predictions for the 2026 World Cup</h1>

          <div class="control-panel">
            <div class="top-controls">
              <div class="mode-toggle">
                <button class="btn ${mode === 'leaderboard' ? 'active' : ''}" onClick=${() => setMode('leaderboard')}>🏆 Leaderboard</button>
                <button class="btn ${mode === 'actual' ? 'active' : ''}" onClick=${() => setMode('actual')}>Official Results</button>
                <button class="btn ${mode === 'user' ? 'active' : ''}" onClick=${() => setMode('user')}>User Predictions</button>
                <button class="btn" onClick=${handleClearAllData}>Reset Data</button>
                <button class="btn" style="background-color: #8b5cf6; border-color: #7c3aed; color: white;" onClick=${() => { setSimulatorUserId(activeUserId); setShowWinnerModal(true); }}>🔮 Can I Win?</button>
              </div>

              <div class="data-controls">
                ${mode === 'actual' && html`
                  <button class="btn" style={{ backgroundColor: '#ef4444', color: 'white' }} onClick=${handleClearOfficial}>
                    🗑️ Clear Official
                  </button>
                `}
                <label class="btn import">📂 Import <input type="file" accept=".json" style="display: none;" onChange=${handleImportData} /></label>
                <button class="btn export" onClick=${handleExportData}>💾 Export</button>
              </div>
            </div>

            ${mode === 'user' && html`
              <div class="user-manager">
                <div class="user-actions">
                  <select class="user-select" value=${activeUserId} onChange=${e => setActiveUserId(e.target.value)}>
                    ${users.map(u => html`<option key=${u.id} value=${u.id}>${u.name}</option>`)}
                  </select>
                  <button class="icon-btn" onClick=${handleRenameUser} title="Rename User">✏️</button>
                  <button class="icon-btn" onClick=${handleDeleteUser} title="Delete User" disabled=${users.length < 1}>🗑️</button>
                </div>
                <form class="add-user-form" onSubmit=${handleAddUser}>
                  <input type="text" class="add-user-input" placeholder="New User Name..." value=${newUserName} onInput=${e => setNewUserName(e.target.value)} />
                  <button type="submit" class="btn">Add</button>
                </form>
              </div>
            `}

            ${mode === 'user' && html`<div class="total-points">${currentUser.name}'s Score: <span>${calculateTotalScore(currentUser.bracket, actualBracket)}</span> pts</div>`}
            ${mode === 'actual' && html`<div class="total-points admin-mode">Official Results</div>`}
            ${mode === 'leaderboard' && html`<div class="total-points" style="color: #cbd5e1;">Leaderboard (Max Possible: 224 pts)</div>`}
          </div>

          ${mode === 'leaderboard' ? html`
            <div class="leaderboard-container">
              <table class="leaderboard-table">
                <thead>
                  <tr>
                    <th>Rank</th>
                    <th>Player Name</th>
                    <th>Total Points</th>
                  </tr>
                </thead>
                <tbody>
                  ${rankedUsers.map((u, index) => html`
                    <tr onClick=${() => { setActiveUserId(u.id); setMode('user'); }}>
                      <td class="rank-cell">
                        ${index === 0 ? '🥇' : index === 1 ? '2nd' : index === 2 ? '3rd' : `${index + 1}th`}
                      </td>
                      <td>${u.name}</td>
                      <td><strong>${u.score}</strong> pts</td>
                    </tr>
                  `)}
                </tbody>
              </table>
            </div>
          ` : html`
            <div class="bracket-board">
              <!-- LEFT BRACKET -->
              <div class="half-bracket left-bracket">
                ${renderColumn(currentBracket.roundOf32.slice(0, 8), 'roundOf32', 0)}
                ${renderColumn(currentBracket.roundOf16.slice(0, 4), 'roundOf16', 0)}
                ${renderColumn(currentBracket.quarterFinals.slice(0, 2), 'quarterFinals', 0)}
                ${renderColumn([currentBracket.semiFinals[0]], 'semiFinals', 0)}
              </div>

              <!-- CENTER COLUMN -->
              <div class="final-column">
                <div class="champion-box">
                  <div class="champion-label">🏆 World Champion</div>
                  <div class="champion-name">${currentBracket.champion}</div>
                </div>
                <div class="final-match-container">
                  <h2>Final</h2>
                  ${renderColumn(currentBracket.final, 'final', 0)}
                </div>
                <div class="third-place-container">
                  <h3>Third Place Match</h3>
                  ${renderColumn(currentBracket.thirdPlace, 'thirdPlace', 0)}
                </div>
              </div>

              <!-- RIGHT BRACKET -->
              <div class="half-bracket right-bracket">
                ${renderColumn(currentBracket.roundOf32.slice(8, 16), 'roundOf32', 8)}
                ${renderColumn(currentBracket.roundOf16.slice(4, 8), 'roundOf16', 4)}
                ${renderColumn(currentBracket.quarterFinals.slice(2, 4), 'quarterFinals', 2)}
                ${renderColumn([currentBracket.semiFinals[1]], 'semiFinals', 1)}
              </div>
            </div>
          `}
          ${showWinnerModal && html`
              <div class="modal-overlay">
                <div class="modal-content">
                  <h3>🔮 Simulate Scenario</h3>
                  <p>Select a user to fill all unplayed official matches with their predictions to see if they can still win.</p>
                  <select class="user-select" value=${simulatorUserId} onChange=${e => setSimulatorUserId(e.target.value)}>
                    ${users.map(u => html`<option key=${u.id} value=${u.id}>${u.name}</option>`)}
                  </select>
                  <div class="modal-actions">
                    <button class="btn" onClick=${() => setShowWinnerModal(false)}>Cancel</button>
                    <button class="btn active" onClick=${handleSimulateWin}>Proceed</button>
                  </div>
                </div>
              </div>
            `}
        </div>
      `;
    }

    render(html`<${WorldCupBracket} />`, document.getElementById('root'));
  </script>
</body>

</html>
