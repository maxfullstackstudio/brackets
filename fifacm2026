<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>2026 World Cup Bracket - Multiplayer</title>

  <style>
    :root {
      --gap-size: 40px;
      --line-width: 20px;
      --line-color: #eab308;
      --line-thick: 2px;
    }

    @media (max-width: 1200px) {
      :root {
        --gap-size: 20px;
        --line-width: 10px;
      }
    }

    body {
      background: radial-gradient(circle at 50% -10%, #1e293b 0%, #020617 100%);
      background-attachment: fixed;
      color: #f8fafc;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      margin: 0;
      padding: 40px 20px;
      overflow-x: auto;
      min-height: 100vh;
    }

    h1 {
      text-align: center;
      font-weight: 900;
      font-size: 2.2rem;
      text-transform: uppercase;
      letter-spacing: 3px;
      margin-bottom: 20px;
      color: #ffffff;
      text-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
    }

    /* --- GAME CONTROLS & POINTS UI --- */
    .control-panel {
      background: rgba(15, 23, 42, 0.8);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 20px;
      max-width: 800px;
      margin: 0 auto 40px auto;
      display: flex;
      flex-direction: column;
      gap: 20px;
      backdrop-filter: blur(10px);
    }

    .top-controls {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 15px;
    }

    .mode-toggle {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .data-controls {
      display: flex;
      gap: 10px;
    }

    .btn {
      background-color: rgba(30, 41, 59, 0.8);
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: #cbd5e1;
      padding: 8px 18px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .btn:hover {
      background-color: rgba(51, 65, 85, 0.8);
      color: #ffffff;
    }

    .btn.active {
      background-color: #eab308;
      color: #000000;
      border-color: #eab308;
      box-shadow: 0 0 10px rgba(234, 179, 8, 0.3);
    }

    .btn.export {
      background-color: #10b981;
      color: #fff;
      border-color: #059669;
    }

    .btn.export:hover {
      background-color: #059669;
    }

    .btn.import {
      background-color: #3b82f6;
      color: #fff;
      border-color: #2563eb;
    }

    .btn.import:hover {
      background-color: #2563eb;
    }

    .user-manager {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 15px;
      background: rgba(0, 0, 0, 0.3);
      padding: 15px;
      border-radius: 8px;
      flex-wrap: wrap;
    }

    .user-actions {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .user-select {
      background: #0f172a;
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.2);
      padding: 8px 12px;
      border-radius: 6px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
    }

    .icon-btn {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: white;
      padding: 8px 10px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 14px;
      transition: all 0.2s ease;
    }

    .icon-btn:hover:not(:disabled) {
      background: rgba(255, 255, 255, 0.15);
    }

    .icon-btn:disabled {
      opacity: 0.3;
      cursor: not-allowed;
    }

    .add-user-form {
      display: flex;
      gap: 8px;
    }

    .add-user-input {
      background: #0f172a;
      color: white;
      border: 1px solid rgba(255, 255, 255, 0.2);
      padding: 8px 12px;
      border-radius: 6px;
    }

    .total-points {
      text-align: center;
      font-size: 18px;
      color: #f8fafc;
      font-weight: 600;
      margin-top: 10px;
    }

    .total-points span {
      color: #4ade80;
      font-size: 26px;
      font-weight: 900;
      margin: 0 6px;
    }

    .total-points.admin-mode {
      color: #fbbf24;
    }

    /* --- POINTS BADGES --- */
    .points-badge {
      position: absolute;
      top: -10px;
      right: -10px;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 11px;
      font-weight: 800;
      z-index: 10;
      box-shadow: 0 2px 5px rgba(0, 0, 0, 0.5);
    }

    .pts-7 {
      background-color: #fde047;
      color: #000;
      border: 2px solid #ca8a04;
    }

    .pts-5 {
      background-color: #4ade80;
      color: #000;
      border: 2px solid #166534;
    }

    .pts-0 {
      background-color: #f87171;
      color: #fff;
      border: 2px solid #991b1b;
    }

    /* --- LEADERBOARD TABLE --- */
    .leaderboard-container {
      max-width: 800px;
      margin: 0 auto;
      background: rgba(15, 23, 42, 0.6);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    }

    .leaderboard-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    .leaderboard-table th,
    .leaderboard-table td {
      padding: 15px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .leaderboard-table th {
      color: #94a3b8;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 12px;
    }

    .leaderboard-table tr:hover td {
      background: rgba(255, 255, 255, 0.03);
    }

    .leaderboard-table td {
      font-size: 16px;
      color: #f8fafc;
      font-weight: 500;
    }

    .leaderboard-table td strong {
      color: #4ade80;
      font-size: 18px;
      font-weight: 800;
    }

    .rank-cell {
      font-weight: bold;
      font-size: 18px !important;
      width: 60px;
    }

    /* --- LAYOUT STRUCTURE --- */
    .bracket-board {
      display: flex;
      justify-content: center;
      align-items: stretch;
      gap: var(--gap-size);
      min-width: max-content;
      min-height: 800px;
    }

    .half-bracket {
      display: flex;
      align-items: stretch;
      gap: var(--gap-size);
    }

    .right-bracket {
      flex-direction: row-reverse;
    }

    .round-column {
      display: flex;
      flex-direction: column;
      width: 190px;
    }

    .final-column {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      margin: 0 10px;
    }

    .match-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
    }

    /* --- MATCH CARDS & INPUTS --- */
    .match-card {
      background-color: rgba(15, 23, 42, 0.6);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      width: 100%;
      display: flex;
      flex-direction: column;
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.5);
      position: relative;
      z-index: 2;
      transition: transform 0.2s ease, background-color 0.2s ease;
    }

    .match-card:hover {
      background-color: rgba(30, 41, 59, 0.8);
      transform: translateY(-2px);
    }

    .team-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 14px;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .team-row:first-child {
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .team-name {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 125px;
    }

    .score-input {
      width: 28px;
      height: 28px;
      background-color: rgba(0, 0, 0, 0.8);
      border: 1px solid rgba(255, 255, 255, 0.3);
      color: white;
      text-align: center;
      border-radius: 2px;
      padding: 0;
      font-weight: 700;
      font-size: 14px;
      transition: all 0.2s ease;
    }

    .score-input:focus {
      outline: none;
      border: 2px solid #fbbf24;
      background-color: #000000;
    }

    .score-input:disabled {
      background-color: transparent;
      border-color: transparent;
      color: rgba(255, 255, 255, 0.3);
    }

    /* --- CHAMPION STYLING --- */
    .champion-box {
      background: linear-gradient(135deg, rgba(234, 179, 8, 0.15), rgba(0, 0, 0, 0.6));
      border: 2px solid #eab308;
      border-radius: 6px;
      padding: 20px 40px;
      margin-bottom: 50px;
      box-shadow: 0 0 25px rgba(234, 179, 8, 0.2);
      text-align: center;
      min-width: 180px;
    }

    .champion-label {
      font-size: 12px;
      text-transform: uppercase;
      color: #fde047;
      letter-spacing: 3px;
      margin-bottom: 8px;
      font-weight: 800;
    }

    .champion-name {
      font-size: 26px;
      font-weight: 900;
      color: #ffffff;
      text-transform: uppercase;
    }

    .final-match-container {
      text-align: center;
    }

    .final-match-container h2 {
      background: linear-gradient(to bottom, #fde047, #ca8a04);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 20px;
      font-size: 28px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .third-place-container {
      margin-top: 50px;
      text-align: center;
    }

    .third-place-container h3 {
      color: #94a3b8;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 15px;
    }

    /* --- CONNECTING LINES --- */
    .match-wrapper::before,
    .match-wrapper::after {
      z-index: 1;
    }

    .left-bracket .round-column:not(:last-child) .match-wrapper:nth-child(odd)::after {
      content: '';
      position: absolute;
      top: 50%;
      right: calc(var(--line-width) * -1);
      width: var(--line-width);
      height: 50%;
      border-top: var(--line-thick) solid var(--line-color);
      border-right: var(--line-thick) solid var(--line-color);
      border-top-right-radius: 4px;
    }

    .left-bracket .round-column:not(:last-child) .match-wrapper:nth-child(even)::after {
      content: '';
      position: absolute;
      bottom: 50%;
      right: calc(var(--line-width) * -1);
      width: var(--line-width);
      height: 50%;
      border-bottom: var(--line-thick) solid var(--line-color);
      border-right: var(--line-thick) solid var(--line-color);
      border-bottom-right-radius: 4px;
    }

    .left-bracket .round-column:not(:first-child) .match-wrapper::before {
      content: '';
      position: absolute;
      top: calc(50% - 1px);
      left: calc(var(--line-width) * -1);
      width: var(--line-width);
      border-top: var(--line-thick) solid var(--line-color);
    }

    .left-bracket .round-column:last-child .match-wrapper::after {
      content: '';
      position: absolute;
      top: calc(50% - 1px);
      right: calc(var(--line-width) * -1);
      width: var(--line-width);
      border-top: var(--line-thick) solid var(--line-color);
    }

    .right-bracket .round-column:not(:last-child) .match-wrapper:nth-child(odd)::after {
      content: '';
      position: absolute;
      top: 50%;
      left: calc(var(--line-width) * -1);
      width: var(--line-width);
      height: 50%;
      border-top: var(--line-thick) solid var(--line-color);
      border-left: var(--line-thick) solid var(--line-color);
      border-top-left-radius: 4px;
    }

    .right-bracket .round-column:not(:last-child) .match-wrapper:nth-child(even)::after {
      content: '';
      position: absolute;
      bottom: 50%;
      left: calc(var(--line-width) * -1);
      width: var(--line-width);
      height: 50%;
      border-bottom: var(--line-thick) solid var(--line-color);
      border-left: var(--line-thick) solid var(--line-color);
      border-bottom-left-radius: 4px;
    }

    .right-bracket .round-column:not(:first-child) .match-wrapper::before {
      content: '';
      position: absolute;
      top: calc(50% - 1px);
      right: calc(var(--line-width) * -1);
      width: var(--line-width);
      border-top: var(--line-thick) solid var(--line-color);
    }

    .right-bracket .round-column:last-child .match-wrapper::after {
      content: '';
      position: absolute;
      top: calc(50% - 1px);
      left: calc(var(--line-width) * -1);
      width: var(--line-width);
      border-top: var(--line-thick) solid var(--line-color);
    }

    .final-match-container .match-wrapper::before {
      content: '';
      position: absolute;
      top: calc(50% - 1px);
      left: calc(var(--line-width) * -1);
      width: var(--line-width);
      border-top: var(--line-thick) solid var(--line-color);
    }

    .final-match-container .match-wrapper::after {
      content: '';
      position: absolute;
      top: calc(50% - 1px);
      right: calc(var(--line-width) * -1);
      width: var(--line-width);
      border-top: var(--line-thick) solid var(--line-color);
    }

    /* --- MODAL STYLING --- */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      background: rgba(0, 0, 0, 0.75);
      backdrop-filter: blur(5px);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 9999;
    }

    .modal-content {
      background: #0f172a;
      padding: 30px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      width: 100%;
      max-width: 400px;
      display: flex;
      flex-direction: column;
      gap: 15px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8);
    }

    .modal-content h3 {
      margin: 0;
      color: #fff;
      font-size: 20px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .modal-content p {
      margin: 0;
      color: #94a3b8;
      font-size: 14px;
      line-height: 1.5;
    }

    .modal-actions {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      margin-top: 10px;
    }

    .leaderboard-table tbody tr {
      cursor: pointer;
    }

    .leaderboard-table tr:hover td {
      background: rgba(255, 255, 255, 0.08);
      /* slightly brightened the hover effect for better feedback */
    }

    /* --- RESPONSIVE ADJUSTMENTS --- */
    @media (max-width: 1200px) {
      .round-column {
        width: 160px;
      }

      .team-name {
        max-width: 100px;
        font-size: 13px;
      }

      .champion-box {
        min-width: 150px;
        padding: 15px 20px;
      }

      .champion-name {
        font-size: 20px;
      }
    }

    @media (max-width: 768px) {
      :root {
        --gap-size: 16px;
        --line-width: 8px;
      }

      body {
        padding: 20px 15px;
        -webkit-overflow-scrolling: touch;
      }

      h1 {
        font-size: 1.8rem;
        margin-bottom: 20px;
      }

      .bracket-board {
        justify-content: flex-start;
        padding-bottom: 30px;
        min-height: 600px;
      }

      .round-column {
        width: 140px;
      }

      .match-card {
        border-radius: 6px;
      }

      .team-row {
        padding: 8px 10px;
        font-size: 12px;
      }

      .team-name {
        max-width: 80px;
      }

      .score-input {
        width: 24px;
        height: 24px;
        font-size: 12px;
      }

      .final-match-container h2 {
        font-size: 20px;
        margin-bottom: 15px;
      }

      .user-manager {
        flex-direction: column;
        align-items: stretch;
      }

      .data-controls {
        flex-direction: column;
        width: 100%;
      }

      .data-controls .btn {
        width: 100%;
      }
    }
  </style>
</head>

